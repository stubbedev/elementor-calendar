# ---- AJAX responses ----
msgid "Security check failed. Please reload the page."
msgstr "Sikkerhedstjek fejlede. Genindlæs siden."

msgid "Thank you! Your time is booked."
msgstr "Tak! Din tid er booket."

msgid "Thank you! Your time is booked. You will receive a confirmation by email."
msgstr "Tak! Din tid er booket. Du modtager en bekræftelse på e-mail."

msgid "Invalid time slot."
msgstr "Ugyldigt tidspunkt."

msgid "Please enter your name and a valid email."
msgstr "Udfyld navn og en gyldig e-mail."

msgid "Please confirm that you are not a robot."
msgstr "Bekræft venligst at du ikke er en robot."

msgid "Sorry, that time is no longer available."
msgstr "Tidspunktet er desværre ikke længere ledigt."

msgid "That time was just taken. Please choose another."
msgstr "Tidspunktet blev netop optaget. Vælg et andet."

# ---- email defaults ----
msgid "New booking: {date} {time}"
msgstr "Ny booking: {date} {time}"

msgid "Name: {name}\nEmail: {email}\nPhone: {phone}\nTime: {date} at {time}\n\nMessage:\n{message}"
msgstr "Navn: {name}\nE-mail: {email}\nTelefon: {phone}\nTid: {date} kl. {time}\n\nBesked:\n{message}"

msgid "Confirmation of your booking {date} at {time}"
msgstr "Bekræftelse på din booking {date} kl. {time}"

msgid "Hi {name}\n\nThank you for your booking.\n\nDate: {date}\nTime: {time}\n\nWe look forward to seeing you. Reply to this email if you need to change the time."
msgstr "Hej {name}\n\nTak for din booking.\n\nDato: {date}\nTid: {time}\n\nVi glæder os til at se dig. Svar på denne mail hvis du skal ændre tiden."

msgid "Booking: {name}"
msgstr "Booking: {name}"

